// /home/jnkoro/mediapost/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  OTHER
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  username     String        @unique
  name         String?
  bio          String?
  password     String
  role         UserRole      @default(USER)
  avatar       Media?        @relation("UserAvatar", fields: [avatarId], references: [id])
  avatarId     String?       @unique
  media        Media[]       @relation("MediaAuthor")
  posts        Post[]        @relation("AuthorPosts")
  comments     Comment[]
  sessions     Session[]
  followers    Follow[]      @relation("FollowingToFollower")
  following    Follow[]      @relation("FollowerToFollowing")
  postLikes    PostLike[]
  commentLikes CommentLike[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Follow {
  follower    User     @relation("FollowerToFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("FollowingToFollower", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model Post {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String
  visibility  Visibility @default(PUBLIC)
  published   Boolean    @default(false)
  publishedAt DateTime?
  author      User       @relation("AuthorPosts", fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String
  media       Media[]    @relation("PostMedia")
  tags        PostTag[]
  comments    Comment[]
  likes       PostLike[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([published, publishedAt])
  @@index([authorId])
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  posts     PostTag[]
  createdAt DateTime  @default(now())
}

model PostTag {
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
}

model Media {
  id        String    @id @default(uuid())
  url       String
  filename  String?
  type      MediaType @default(IMAGE)
  size      Int?
  width     Int?
  height    Int?
  metadata  Json?
  // relation to the uploading user (one-to-many)
  author    User?     @relation("MediaAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  // reverse side of the user's avatar (one-to-one)
  avatarOf  User?     @relation("UserAvatar")
  post      Post?     @relation("PostMedia", fields: [postId], references: [id], onDelete: Cascade)
  postId    String?
  createdAt DateTime  @default(now())
}

model Comment {
  id        String        @id @default(uuid())
  content   String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String?
  replies   Comment[]     @relation("CommentReplies")
  likes     CommentLike[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postId])
  @@index([authorId])
}

model PostLike {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model CommentLike {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
}

model AppSettings {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
}

model CommentDelete {
  id                String   @id @default(uuid())
  userId            String
  commentId         String
  createdAt         DateTime @default(now())
  commendDeleteData DateTime @default(now())
}

model CommentDelete2 {
  id                String   @id @default(uuid())
  userId            String
  commentId         String
  createdAt         DateTime @default(now())
  commendDeleteData DateTime @default(now())
}
